# MediLingua environment configuration
# Copy this file to .env and adjust values as needed.
# The backend works with these defaults if .env is absent.

# Auth
SECRET_KEY=ai-platform-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite by default; swap to PostgreSQL for production)
# PLATFORM_DATABASE_URL is used to avoid clashing with Next.js's DATABASE_URL
PLATFORM_DATABASE_URL=sqlite:///./backend/data/platform.db

# LLM Service (z-ai-web-dev-sdk mini-service on port 3003)
LLM_SERVICE_URL=http://localhost:3003

# CORS (allow all origins for demo; restrict in production)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
